# --- Server ---
PORT=5000

# --- MongoDB ---
# Easiest local dev (no Atlas): data is lost when the server stops
USE_IN_MEMORY_DB=true
MONGODB_DB_NAME=auth_app

# Cloud Atlas — set USE_IN_MEMORY_DB=false, then use ONE of:
#
# Option A — full URI (Database → Connect → Drivers):
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/auth_app?retryWrites=true&w=majority&appName=Cluster0
#
# Option B — split (password auto-encoded):
# MONGODB_USER=mydbuser
# MONGODB_PASSWORD=my_plain_password
# MONGODB_CLUSTER_HOST=cluster0.xxxxx.mongodb.net
# MONGODB_DB_NAME=auth_app
#
# Network Access → allow your IP. Windows SRV issues: MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1

# --- Auth ---
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# --- CORS ---
# Comma-separated for multiple frontends (e.g. local + Vercel):
# CLIENT_ORIGIN=http://localhost:5173,https://your-app.vercel.app
CLIENT_ORIGIN=http://localhost:5173
